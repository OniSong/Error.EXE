<?xml version="1.0" encoding="utf-8"?>
<!-- Gothic/punk overlay border — neon double-stroke with sharp corners -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow layer (crimson) -->
    <item
        android:left="-2dp"
        android:top="-2dp"
        android:right="-2dp"
        android:bottom="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#44FF003C" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Purple mid border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#779B00FF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Inner neon green hairline -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#AA00FF9F" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
