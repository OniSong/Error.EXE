<?xml version="1.0" encoding="utf-8"?>
<!-- Fait AI message row — icon left, bubble right of icon -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:gravity="start"
    android:orientation="horizontal">

    <!-- Fait avatar icon — ⛩ in a neon circle -->
    <TextView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/icon_fait_bg"
        android:gravity="center"
        android:text="⛩"
        android:textSize="13sp" />

    <!-- Bubble + name group -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="Fait"
            android:textColor="#5500FF9F"
            android:textSize="8sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_fait"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:textColor="@color/bubble_fait_text"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Spacer so bubble doesn't stretch full width -->
    <View android:layout_width="40dp" android:layout_height="1dp" />

</LinearLayout>
