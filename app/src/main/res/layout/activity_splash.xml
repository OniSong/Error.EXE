<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Scanline overlay for CRT glitch effect -->
    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#08FFFFFF"
        android:alpha="0" />

    <TextView
        android:id="@+id/terminalText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:fontFamily="monospace"
        android:textSize="22sp"
        android:textColor="#8A2BE2"
        android:text="" />

    <TextView
        android:id="@+id/glitch_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace"
        android:textSize="22sp"
        android:textColor="#FF0066"
        android:alpha="0"
        android:text="" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/terminalText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:textColor="#00FF00"
        android:visibility="gone" />

</RelativeLayout>
