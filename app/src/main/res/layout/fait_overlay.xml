<?xml version="1.0" encoding="utf-8"?>
<!--
    Fait Overlay — Gothic/Punk/Japanese chat interface
    ─ Draggable via title bar (tap-drag or long-press)
    ─ α button cycles opacity levels
    ─ 壁 button cycles chat background themes
    ─ — button minimizes to title bar
    ─ Gemini-style input bar at bottom (text + mic + send)
    ─ Scrollable chat history with user/AI bubbles + icons
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="300dp"
    android:layout_height="420dp"
    android:background="@drawable/overlay_border">

    <!-- Outer container with border effect -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="3dp"
        android:orientation="vertical"
        android:background="@color/bg_void"
        android:clipChildren="true">

        <!-- ═══════════════════════════════════════════
             TITLE BAR / DRAG HANDLE
             ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/drag_handle"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@drawable/drag_handle_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <!-- Grip + title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="⛩ FAIT.EXE"
                android:textColor="#CC00FF9F"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Background cycle button (壁 = wall/background) -->
            <ImageView
                android:id="@+id/btn_bg"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/icon_bg_cycle"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="cycle background" />

            <!-- Opacity button -->
            <TextView
                android:id="@+id/btn_opacity"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="α"
                android:textColor="#AA00FF9F"
                android:textSize="13sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Minimize button -->
            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="—"
                android:textColor="#AA9B00FF"
                android:textSize="13sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════
             COLLAPSIBLE CONTENT (hidden when minimized)
             ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/overlay_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Chat scroll area with changeable background -->
            <ScrollView
                android:id="@+id/chat_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/chat_bg_void"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:scrollbars="none"
                android:fadeScrollbars="true">

                <LinearLayout
                    android:id="@+id/chat_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </ScrollView>

            <!-- Status strip between chat and input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:background="#EE050508"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="online"
                    android:textColor="#5500FF9F"
                    android:textSize="8sp"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <!-- ═════════════════════════════════════
                 INPUT BAR (Gemini-style)
                 ═════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bar_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <!-- Text input pill (Gemini-style) -->
                <EditText
                    android:id="@+id/input_field"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/input_field_bg"
                    android:fontFamily="monospace"
                    android:hint="message Fait..."
                    android:imeOptions="actionSend|flagNoExtractUi"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="3"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/bubble_user_text"
                    android:textColorHint="#3300FF9F"
                    android:textSize="11sp" />

                <!-- Mic button (purple — like Gemini voice) -->
                <ImageView
                    android:id="@+id/btn_mic"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:padding="7dp"
                    android:src="@drawable/icon_mic"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="voice input" />

                <!-- Send button (neon green) -->
                <ImageView
                    android:id="@+id/btn_send"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:padding="7dp"
                    android:src="@drawable/icon_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="send" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
