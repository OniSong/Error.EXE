<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!--
        Phase B: SceneView replaced by Unity companion app.
        This view is kept as GONE so no SceneView dependency needed.
        Phase A (UaaL): swap this for UnityPlayer view.
    -->
    <View
        android:id="@+id/scene_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- Speech bubble — positioned bottom-right, floats above Unity avatar window -->
    <TextView
        android:id="@+id/speech_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:background="@drawable/overlay_background"
        android:fontFamily="monospace"
        android:maxWidth="260dp"
        android:padding="10dp"
        android:text=""
        android:textColor="#00FF00"
        android:textSize="12sp"
        android:visibility="gone" />

</FrameLayout>
