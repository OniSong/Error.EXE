<?xml version="1.0" encoding="utf-8"?>
<!--
    Fait Overlay — draggable, transparent box
    Long-press drag handle to reposition anywhere on screen.
    Tap the α button to cycle transparency levels.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_card"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC0D0D0D"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Drag Handle / Title Bar ── -->
        <LinearLayout
            android:id="@+id/drag_handle"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#1500FF00"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="4dp">

            <!-- Drag grip dots -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="⠿ FAIT"
                android:textColor="#8000FF00"
                android:textSize="11sp" />

            <!-- Transparency toggle button -->
            <TextView
                android:id="@+id/btn_opacity"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="α"
                android:textColor="#00FF00"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingBottom="2dp" />

            <!-- Minimize button -->
            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="—"
                android:textColor="#00FF00"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2200FF00" />

        <!-- ── Content area (hidden when minimized) ── -->
        <LinearLayout
            android:id="@+id/overlay_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Speech bubble text — typewriter effect applied in code -->
            <TextView
                android:id="@+id/speech_bubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3"
                android:minHeight="40dp"
                android:text=""
                android:textColor="#00FF00"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Input row -->
            <LinearLayout
                android:id="@+id/input_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <EditText
                    android:id="@+id/input_field"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:fontFamily="monospace"
                    android:hint="say something..."
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="3"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="#00FF00"
                    android:textColorHint="#3300FF00"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/btn_send"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="▶"
                    android:textColor="#00FF00"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Status indicator row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="initializing..."
                    android:textColor="#5500FF00"
                    android:textSize="9sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
