<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/permissionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ SYSTEM ACCESS REQUIRED"
        android:textSize="20sp"
        android:textColor="#8A2BE2"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/permissionMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:fontFamily="monospace"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="24dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="CANCEL"
            android:textSize="14sp"
            android:textColor="#666666"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="@drawable/button_background_secondary"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/grantButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="GRANT ACCESS"
            android:textSize="14sp"
            android:textColor="#00FF00"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="@drawable/button_background_primary"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
